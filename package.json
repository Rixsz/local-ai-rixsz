{
  "name": "local-ai-web",
  "version": "1.0.0",
  "description": "Local AI workspace with Web-Augmented Intelligence",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder build --win"
  },
  "build": {
    "appId": "com.rixsz.localai",
    "productName": "Local AI Web",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.png"
    },
    "files": [
      "**/*",
      "!dist-electron/**/*"
    ]
  },
  "dependencies": {
    "electron": "^25.8.1"
  },
  "devDependencies": {
    "electron-builder": "^24.6.4"
  }
}

